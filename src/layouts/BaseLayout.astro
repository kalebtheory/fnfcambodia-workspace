---
// src/layouts/BaseLayout.astro
// Crush Combat brand layout — agency + media house
// Static navbar/footer for SEO, interactive islands for mobile menu & dropdown

import MobileMenu from "../components/MobileMenu";
import NavDropdown from "../components/NavDropdown";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Architects of the Combat Economy. Southeast Asia's MMA talent agency and broadcast media house. Powering Khmer Flow Arena.",
  ogImage,
} = Astro.props;
const currentPath = Astro.url.pathname;

// Navigation — Crush Combat IA
const navLinks = [
  {
    label: "Roster",
    path: "/fighters",
    submenu: [
      { label: "Full Roster", path: "/fighters" },
      { label: "Kun Khmer", path: "/fighters?discipline=kun-khmer" },
      { label: "MMA", path: "/fighters?discipline=mma" },
      { label: "Grappling", path: "/fighters?discipline=grappling" },
    ],
  },
  { label: "Events", path: "/events" },
  { label: "Media", path: "/watch" },
  { label: "Stories", path: "/stories" },
  { label: "About", path: "/about" },
];

const flatNavLinks = navLinks.filter((l) => !l.submenu);
const dropdownLinks = navLinks.filter((l) => l.submenu);

// Bottom nav for mobile
const bottomNavLinks = [
  { label: "Home", path: "/", icon: "home" },
  { label: "Media", path: "/watch", icon: "video" },
  { label: "Events", path: "/events", icon: "map-pin" },
  { label: "Roster", path: "/fighters", icon: "users" },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Crush Combat" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body
    class="min-h-screen bg-brand-dark text-brand-light font-sans flex flex-col relative w-full overflow-x-hidden"
  >
    <!-- NAVBAR -->
    <nav
      id="main-nav"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent h-20 sm:h-24"
    >
      <div
        class="max-w-7xl mx-auto px-6 sm:px-8 h-full flex items-center justify-between"
      >
        <!-- Mobile menu + Logo -->
        <div class="flex items-center gap-4 sm:gap-6">
          <MobileMenu
            client:load
            navLinks={navLinks}
            currentPath={currentPath}
            registerPath="/apply"
            registerLabel="Apply"
            logoSrc="/crush-combat-logo.png"
          />
          <a
            href="/"
            class="hover:opacity-80 transition-opacity shrink-0 flex items-center gap-2"
          >
            <!-- Text wordmark fallback when logo PNG is missing -->
            <span
              class="font-display font-black text-base sm:text-lg uppercase tracking-tight text-brand-light"
            >
              Crush <span class="text-brand-gold">Combat</span>
            </span>
          </a>
        </div>

        <!-- Desktop nav -->
        <div
          class="hidden lg:flex items-center gap-8 text-[11px] font-black uppercase tracking-[0.2em] text-white"
        >
          {
            dropdownLinks.map((link) => (
              <NavDropdown
                client:load
                label={link.label}
                items={link.submenu!}
                currentPath={currentPath}
              />
            ))
          }
          {
            flatNavLinks.map((link) => {
              const isActive = currentPath === link.path;
              return (
                <a
                  href={link.path}
                  class={`hover:text-brand-gold transition-colors ${isActive ? "text-brand-gold" : ""}`}
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>

        <!-- Right: Lang + CTA -->
        <div class="flex items-center gap-3 sm:gap-4">
          <div class="flex items-center gap-1 sm:gap-2 ml-2">
            <a
              href="/"
              class="px-2 py-1 text-[10px] sm:text-xs font-black uppercase tracking-[0.2em] text-brand-gold"
              title="English">EN</a
            >
            <div class="w-[1px] h-3 bg-white/10"></div>
            <a
              href="/km"
              class="px-2 py-1 text-[10px] sm:text-xs font-black uppercase tracking-[0.2em] text-white/40 hover:text-white transition-all"
              title="ភាសាខ្មែរ">KH</a
            >
          </div>
          <a
            href="/apply"
            class="hidden xs:flex bg-brand-gold text-black px-6 py-2.5 font-bold rounded-xl text-[10px] uppercase tracking-[0.2em] items-center gap-2 hover:bg-white transition-all shadow-[0_0_20px_rgba(212,175,55,0.2)] active:scale-95"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><line
                x1="19"
                y1="8"
                x2="19"
                y2="14"></line><line x1="22" y1="11" x2="16" y2="11"
              ></line></svg
            >
            <span class="hidden sm:inline">Apply</span>
          </a>
        </div>
      </div>
    </nav>

    <!-- MOBILE BOTTOM NAV -->
    <div
      class="lg:hidden fixed bottom-0 left-0 right-0 z-[60] bg-brand-dark/80 backdrop-blur-3xl border-t border-white/5 pb-safe"
    >
      <div
        class="max-w-md mx-auto px-6 py-3 flex items-center justify-between"
      >
        {
          bottomNavLinks.map((link) => {
            const isActive = currentPath === link.path;
            return (
              <a
                href={link.path}
                class={`relative flex flex-col items-center justify-center py-2 transition-all duration-300 min-w-[64px] ${
                  isActive
                    ? "text-brand-gold scale-110"
                    : "text-white/60 hover:text-white"
                }`}
              >
                {link.icon === "home" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                  </svg>
                )}
                {link.icon === "video" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m22 8-6 4 6 4V8Z" />
                    <rect width="14" height="12" x="2" y="6" rx="2" ry="2" />
                  </svg>
                )}
                {link.icon === "map-pin" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {link.icon === "users" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
                <span class="text-[9px] font-black uppercase tracking-widest mt-1.5">
                  {link.label}
                </span>
                {isActive && (
                  <div class="absolute -bottom-1 w-1 h-1 bg-brand-gold rounded-full shadow-[0_0_10px_rgba(255,212,63,1)]" />
                )}
              </a>
            );
          })
        }
        <a
          href="/apply"
          class="flex flex-col items-center justify-center p-2 rounded-2xl bg-brand-gold text-black shadow-lg shadow-brand-gold/20 transition-all duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
            ></path><circle cx="9" cy="7" r="4"></circle><line
              x1="19"
              y1="8"
              x2="19"
              y2="14"></line><line x1="22" y1="11" x2="16" y2="11"
            ></line></svg
          >
        </a>
      </div>
    </div>

    <!-- MAIN -->
    <main class="flex-1 w-full pb-28 lg:pb-0">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer
      class="border-t border-white/5 bg-brand-darker pt-20 pb-12 mt-auto relative z-10 w-full overflow-hidden"
    >
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
          <!-- Brand -->
          <div class="col-span-1 md:col-span-2 pr-4">
            <a
              href="/"
              class="hover:opacity-80 transition-opacity inline-block mb-6 font-display font-black text-2xl uppercase tracking-tight text-brand-light"
            >
              Crush <span class="text-brand-gold">Combat</span>
            </a>
            <p class="text-[#888] font-medium max-w-sm mb-6 leading-relaxed">
              Architects of the Combat Economy. Southeast Asia's MMA talent
              agency and broadcast media house. Phnom Penh · Global reach.
            </p>
            <div class="flex items-center gap-4">
              {
                [
                  {
                    label: "Facebook",
                    href: "https://www.facebook.com/crushcombat/",
                    d: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
                  },
                  {
                    label: "LinkedIn",
                    href: "https://www.linkedin.com/services/page/769b653408862b6a63/",
                    d: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z",
                    extra:
                      '<rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
                  },
                  {
                    label: "Instagram",
                    href: "#",
                    d: "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z",
                    extra:
                      '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
                  },
                  {
                    label: "YouTube",
                    href: "#",
                    d: "M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17",
                    extra: '<polygon points="10 15 15 12 10 9"/>',
                  },
                ].map((social) => (
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener"
                    aria-label={social.label}
                    class="w-10 h-10 rounded-full bg-white/5 border border-white/5 flex items-center justify-center text-[#888] hover:text-brand-gold hover:border-brand-gold/30 hover:bg-brand-gold/5 transition-all"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d={social.d} />
                      {social.extra && (
                        <Fragment set:html={social.extra} />
                      )}
                    </svg>
                  </a>
                ))
              }
            </div>
          </div>

          <!-- Agency -->
          <div>
            <h3 class="text-brand-light font-semibold mb-6 flex items-center text-sm">
              <span class="w-1 h-1 bg-brand-gold rounded-full mr-2"></span>
              Agency
            </h3>
            <ul class="space-y-4 text-[#888] text-sm font-medium">
              <li><a href="/apply" class="hover:text-brand-light transition-colors">Apply for Representation</a></li>
              <li><a href="/partner" class="hover:text-brand-light transition-colors">Partner with Us</a></li>
              <li><a href="/fighters" class="hover:text-brand-light transition-colors">Full Roster</a></li>
              <li><a href="/about" class="hover:text-brand-light transition-colors">About Crush Combat</a></li>
              <li><a href="/contact" class="hover:text-brand-light transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Ecosystem -->
          <div>
            <h3 class="text-brand-light font-semibold mb-6 flex items-center text-sm">
              <span class="w-1 h-1 bg-brand-gold rounded-full mr-2"></span>
              Ecosystem
            </h3>
            <ul class="space-y-4 text-[#888] text-sm font-medium">
              <li><a href="https://khmerflow.com" target="_blank" rel="noopener" class="hover:text-brand-light transition-colors">Khmer Flow Arena</a></li>
              <li><a href="https://khmerflow.com" target="_blank" rel="noopener" class="hover:text-brand-light transition-colors">Khmer Flow Apparel</a></li>
              <li><a href="/events" class="hover:text-brand-light transition-colors">Upcoming Events</a></li>
              <li><a href="/watch" class="hover:text-brand-light transition-colors">Media Vault</a></li>
              <li><a href="/stories" class="hover:text-brand-light transition-colors">Stories</a></li>
            </ul>
          </div>
        </div>

        <div
          class="flex flex-col md:flex-row items-center justify-between pt-8 border-t border-white/5 text-xs font-medium text-[#555]"
        >
          <p>
            &copy; {new Date().getFullYear()} Crush Combat Agency. All rights reserved.
          </p>
          <div class="flex gap-6 mt-4 md:mt-0">
            <a href="/sitemap" class="hover:text-[#888] transition-colors">Sitemap</a>
            <a href="/privacy-policy" class="hover:text-[#888] transition-colors">Privacy</a>
            <a href="/terms-of-use" class="hover:text-[#888] transition-colors">Terms</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Navbar scroll behavior -->
    <script>
      const nav = document.getElementById("main-nav");
      let lastScrollY = 0;

      window.addEventListener(
        "scroll",
        () => {
          const currentScrollY = window.scrollY;

          if (nav) {
            if (currentScrollY > 20) {
              nav.classList.add("backdrop-blur-md", "h-16", "sm:h-20");
              nav.classList.remove("h-20", "sm:h-24");
            } else {
              nav.classList.remove("backdrop-blur-md", "h-16", "sm:h-20");
              nav.classList.add("h-20", "sm:h-24");
            }

            if (currentScrollY > lastScrollY && currentScrollY > 100) {
              nav.classList.add("-translate-y-full");
            } else {
              nav.classList.remove("-translate-y-full");
            }
          }

          lastScrollY = currentScrollY;
        },
        { passive: true }
      );
    </script>
  </body>
</html>
