---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const fighters = await getCollection("fighters");
  return fighters.map((fighter) => ({
    params: { slug: fighter.id.replace(/\.md$/, '') },
    props: { fighter },
  }));
}

const { fighter } = Astro.props;
const { Content } = await fighter.render();
const { name, style, weightClass, kunKhmerRecord, mmaRecord, heroImage } = fighter.data;

// Compute combined totals for the hero stats
const kkW = kunKhmerRecord?.wins ?? 0;
const kkL = kunKhmerRecord?.losses ?? 0;
const kkD = kunKhmerRecord?.draws ?? 0;
const mmaW = mmaRecord?.wins ?? 0;
const mmaL = mmaRecord?.losses ?? 0;
const mmaD = mmaRecord?.draws ?? 0;
const totalWins = kkW + mmaW;
const totalLosses = kkL + mmaL;
const totalDraws = kkD + mmaD;
const totalFights = totalWins + totalLosses + totalDraws;
const winRate = totalFights > 0 ? Math.round((totalWins / totalFights) * 100) : 0;

// Build SEO description
const kkStr = kunKhmerRecord ? `KK: ${kkW}W-${kkL}L-${kkD}D` : '';
const mmaStr = mmaRecord ? `MMA: ${mmaW}W-${mmaL}L-${mmaD}D` : '';
const recordStr = [kkStr, mmaStr].filter(Boolean).join(' | ');
---

<BaseLayout
  title={`${name} — FNF Cambodia Fighter Profile`}
  description={`${name} is a ${style} fighter competing at ${weightClass} in FNF Cambodia. ${recordStr}`}
  ogImage={heroImage}
>
  <article class="pt-28 sm:pt-36 pb-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 sm:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.2em] text-white/30">
        <a href="/" class="hover:text-white/60 transition-colors">Home</a>
        <span>/</span>
        <a href="/fighters" class="hover:text-white/60 transition-colors">Fighters</a>
        <span>/</span>
        <span class="text-brand-gold">{name}</span>
      </nav>

      <!-- Hero Card -->
      <div class="bg-[#0a0a0a] rounded-3xl border border-white/5 overflow-hidden mb-12">
        <!-- Hero image area -->
        <div class="aspect-[21/9] bg-gradient-to-br from-brand-gold/15 via-brand-gold/5 to-transparent relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent z-10"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 sm:p-10 z-20">
            <div class="flex items-end justify-between gap-4">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  {kunKhmerRecord && (
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full border text-brand-gold border-brand-gold/30 bg-brand-gold/10">
                      Kun Khmer
                    </span>
                  )}
                  {mmaRecord && (
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full border text-blue-400 border-blue-400/30 bg-blue-400/10">
                      MMA
                    </span>
                  )}
                  <span class="text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full border border-white/10 text-white/50 bg-white/5">
                    {weightClass}
                  </span>
                </div>
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tighter">
                  {name}
                </h1>
              </div>
            </div>
          </div>
        </div>

        <!-- Combined Overview Stats -->
        <div class="px-8 sm:px-10 py-5 flex flex-wrap items-center gap-8 border-t border-white/5">
          <div class="text-center">
            <span class="text-2xl font-black text-green-400">{totalWins}</span>
            <span class="block text-[9px] font-bold uppercase tracking-widest text-white/30 mt-1">Wins</span>
          </div>
          <div class="text-center">
            <span class="text-2xl font-black text-red-400">{totalLosses}</span>
            <span class="block text-[9px] font-bold uppercase tracking-widest text-white/30 mt-1">Losses</span>
          </div>
          <div class="text-center">
            <span class="text-2xl font-black text-white/40">{totalDraws}</span>
            <span class="block text-[9px] font-bold uppercase tracking-widest text-white/30 mt-1">Draws</span>
          </div>
          <div class="h-8 w-[1px] bg-white/5 hidden sm:block"></div>
          <div class="text-center">
            <span class="text-2xl font-black text-brand-gold">{winRate}%</span>
            <span class="block text-[9px] font-bold uppercase tracking-widest text-white/30 mt-1">Win Rate</span>
          </div>
          <div class="text-center">
            <span class="text-2xl font-black text-white/60">{totalFights}</span>
            <span class="block text-[9px] font-bold uppercase tracking-widest text-white/30 mt-1">Total</span>
          </div>
        </div>

        <!-- Discipline-Specific Record Blocks -->
        <div class={`px-8 sm:px-10 py-6 border-t border-white/5 ${kunKhmerRecord && mmaRecord ? 'grid grid-cols-1 sm:grid-cols-2 gap-6' : ''}`}>
          {kunKhmerRecord && (
            <div class="bg-white/[0.02] rounded-2xl border border-white/5 p-5">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-gold"></span>
                <span class="text-[10px] font-black uppercase tracking-[0.25em] text-brand-gold">Kun Khmer Record</span>
              </div>
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-3xl font-black text-green-400">{kunKhmerRecord.wins}</span>
                <span class="text-xl font-black text-white/15">-</span>
                <span class="text-3xl font-black text-red-400">{kunKhmerRecord.losses}</span>
                <span class="text-xl font-black text-white/15">-</span>
                <span class="text-3xl font-black text-white/40">{kunKhmerRecord.draws}</span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-white/25 ml-2">W-L-D</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-lg font-black text-brand-gold">{kunKhmerRecord.kos}</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-brand-gold/60">KOs</span>
                <div class="flex-1 h-1.5 bg-white/5 rounded-full ml-2 overflow-hidden">
                  <div class="h-full bg-brand-gold/60 rounded-full" style={`width: ${kunKhmerRecord.wins > 0 ? Math.round((kunKhmerRecord.kos / kunKhmerRecord.wins) * 100) : 0}%`}></div>
                </div>
                <span class="text-[9px] font-bold text-white/25">{kunKhmerRecord.wins > 0 ? Math.round((kunKhmerRecord.kos / kunKhmerRecord.wins) * 100) : 0}% KO Rate</span>
              </div>
            </div>
          )}

          {mmaRecord && (
            <div class="bg-white/[0.02] rounded-2xl border border-white/5 p-5">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                <span class="text-[10px] font-black uppercase tracking-[0.25em] text-blue-400">MMA Record</span>
              </div>
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-3xl font-black text-green-400">{mmaRecord.wins}</span>
                <span class="text-xl font-black text-white/15">-</span>
                <span class="text-3xl font-black text-red-400">{mmaRecord.losses}</span>
                <span class="text-xl font-black text-white/15">-</span>
                <span class="text-3xl font-black text-white/40">{mmaRecord.draws}</span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-white/25 ml-2">W-L-D</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-lg font-black text-brand-gold">{mmaRecord.kos}</span>
                <span class="text-[9px] font-black uppercase tracking-widest text-brand-gold/60">KOs</span>
                <div class="flex-1 h-1.5 bg-white/5 rounded-full ml-2 overflow-hidden">
                  <div class="h-full bg-blue-400/60 rounded-full" style={`width: ${mmaRecord.wins > 0 ? Math.round((mmaRecord.kos / mmaRecord.wins) * 100) : 0}%`}></div>
                </div>
                <span class="text-[9px] font-bold text-white/25">{mmaRecord.wins > 0 ? Math.round((mmaRecord.kos / mmaRecord.wins) * 100) : 0}% KO Rate</span>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Markdown Body -->
      <div class="prose-fighter max-w-none">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-16 pt-8 border-t border-white/5">
        <a href="/fighters" class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.2em] text-white/40 hover:text-brand-gold transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          Back to Roster
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
