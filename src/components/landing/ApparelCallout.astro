---
// Apparel Callout — outbound link to khmerflow.com (ecosystem partner)
---

<section class="py-24 sm:py-32 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 sm:px-8">
    <div
      class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-0 items-stretch border border-white/10 rounded-lg overflow-hidden bg-brand-darker"
    >
      <!-- Image side -->
      <div
        class="relative aspect-[4/3] lg:aspect-auto lg:min-h-[400px] bg-cover bg-center"
        style="background-image:url('/apparel/khmerflow.jpg');"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-brand-darker/40 via-transparent to-transparent"></div>
      </div>

      <!-- Copy side -->
      <div class="p-8 sm:p-12 lg:p-16 flex flex-col justify-center">
        <span
          class="text-brand-gold text-[10px] font-black uppercase tracking-[0.3em] mb-4 block"
        >
          Official Apparel
        </span>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-display font-black uppercase tracking-tighter mb-6"
        >
          Wear the <span class="text-brand-gold">Lineage.</span>
        </h2>
        <p class="text-base sm:text-lg text-white/60 font-medium leading-relaxed mb-8">
          Khmer Flow is the official apparel of Khmer Flow Arena —
          ancestral heritage and modern discipline, forged in Phnom Penh.
        </p>
        <a
          href="https://khmerflow.com"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 text-[11px] font-black uppercase tracking-[0.25em] bg-white text-black hover:bg-brand-gold transition-all rounded-lg active:scale-95 w-fit group"
        >
          Shop Khmer Flow
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover:translate-x-1 transition-transform"
            ><path d="M7 17 17 7"></path><path d="M7 7h10v10"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</section>
