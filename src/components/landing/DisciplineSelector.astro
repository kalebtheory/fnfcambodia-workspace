---
// Discipline Selector — three large image-tiles, fighter-apply funnel entry
// Each tile → /apply?discipline={slug}
const disciplines = [
  {
    name: "MMA",
    slug: "mma",
    blurb: "Cage. Strikes. Submissions.",
    image: "/disciplines/mma.jpg",
  },
  {
    name: "Kun Khmer",
    slug: "kun-khmer",
    blurb: "Ancient art. Modern stage.",
    image: "/disciplines/kun-khmer.jpg",
  },
  {
    name: "Grappling",
    slug: "grappling",
    blurb: "Gi · No-Gi · Submission only.",
    image: "/disciplines/grappling.jpg",
  },
];
---

<section class="py-24 sm:py-32 relative">
  <div class="max-w-7xl mx-auto px-6 sm:px-8">
    <!-- Header -->
    <div class="mb-16 text-center">
      <span
        class="text-brand-gold text-[10px] font-black uppercase tracking-[0.3em] mb-4 block"
      >
        Pick Your Discipline
      </span>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-display font-black uppercase tracking-tighter"
      >
        Three Codes. <span class="text-brand-gold">One Roster.</span>
      </h2>
    </div>

    <!-- Tiles -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
      {
        disciplines.map((d) => (
          <a
            href={`/apply?discipline=${d.slug}`}
            class="group relative aspect-[3/4] overflow-hidden rounded-lg border border-white/5 hover:border-brand-gold/40 transition-all"
          >
            {/* Photo */}
            <div
              class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
              style={`background-image:url('${d.image}');`}
            />
            {/* Fallback dark layer if image missing */}
            <div class="absolute inset-0 bg-gradient-to-br from-brand-darker via-brand-dark to-black/80" />
            <div
              class="absolute inset-0 bg-cover bg-center opacity-70 transition-opacity duration-500 group-hover:opacity-90"
              style={`background-image:url('${d.image}');`}
            />
            {/* Bottom gradient for type legibility */}
            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black via-black/70 to-transparent" />
            {/* Content */}
            <div class="absolute inset-0 p-6 sm:p-8 flex flex-col justify-end">
              <h3 class="text-3xl sm:text-4xl md:text-5xl font-display font-black uppercase tracking-tighter text-white mb-2">
                {d.name}
              </h3>
              <p class="text-sm text-white/60 font-medium mb-6">{d.blurb}</p>
              <span class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.3em] text-brand-gold group-hover:gap-3 transition-all">
                Apply
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
