---
// Roster Strip — featured fighter cards, links to /fighters
import { getCollection } from "astro:content";
import FighterCard from "../FighterCard.astro";

const all = await getCollection("fighters");
// Take first 6 for landing strip
const featured = all.slice(0, 6);
---

<section class="py-24 sm:py-32 relative bg-brand-darker border-y border-white/5">
  <div class="max-w-7xl mx-auto px-6 sm:px-8">
    <!-- Header -->
    <div
      class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-16 gap-6"
    >
      <div>
        <span
          class="text-brand-gold text-[10px] font-black uppercase tracking-[0.3em] mb-3 block"
        >
          The Roster
        </span>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-display font-black uppercase tracking-tighter"
        >
          Talent <span class="text-brand-gold">In Camp.</span>
        </h2>
      </div>
      <a
        href="/fighters"
        class="text-[11px] font-black uppercase tracking-[0.25em] text-white/50 hover:text-brand-gold transition-colors flex items-center gap-2 group"
      >
        View Full Roster
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:translate-x-1 transition-transform"
          ><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {featured.map((fighter) => <FighterCard fighter={fighter} />)}
    </div>
  </div>
</section>
